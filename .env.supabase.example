# ===================================================================
# Supabase 데이터베이스 연결 설정 가이드
# ===================================================================
#
# 이 파일은 Supabase 연결을 위한 예제입니다.
# 실제 값으로 교체한 후 .env 파일로 복사하세요.
#
# ===================================================================

# Database (Supabase PostgreSQL)
#
# Supabase에서 CONNECTION STRING 받는 방법:
# 1. https://supabase.com 로그인
# 2. 프로젝트 선택
# 3. Settings → Database 메뉴
# 4. Connection pooling 섹션에서:
#    - "Use connection pooling" 토글 ON
#    - Mode: "Transaction" 선택
#    - Connection string 복사
#
# 형식:
# DATABASE_URL="postgresql://postgres.xxxxx:[sr1234]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres"
#
# 주의: [YOUR-PASSWORD]를 실제 비밀번호로 교체하세요!
DATABASE_URL="postgresql://postgres.xxxxx:[sr1234]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres"

# Direct connection (마이그레이션 실행 시 사용)
# Settings → Database → Connection string 섹션에서
# "URI" 탭의 연결 문자열 복사
DIRECT_URL="postgresql://postgres:[sr1234]@db.xxxxx.supabase.co:5432/postgres"

# NextAuth
# Production에서는 반드시 변경하세요!
# 생성 방법: openssl rand -base64 32
NEXTAUTH_SECRET="temporary-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3001"

# Vercel Blob (추후 설정)
# BLOB_READ_WRITE_TOKEN=""

# Upstash Redis (추후 설정)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Resend (이메일 발송 서비스)
# https://resend.com에서 API 키 발급
# 1. https://resend.com 로그인
# 2. API Keys → Create API Key
# 3. Domain 추가 (선택사항, 없으면 테스트 모드)
RESEND_API_KEY=""
EMAIL_FROM="SR Management <noreply@sr-system.com>"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Inngest (추후 설정)
# INNGEST_EVENT_KEY=""
# INNGEST_SIGNING_KEY=""

# Mattermost (선택사항)
# MATTERMOST_WEBHOOK_URL=""
