{
  "extends": [
    "next/core-web-vitals",
		"plugin:import/recommended"
  ],
  "plugins": [
		"import"
  ],
  "rules": {
		"no-console": "warn",
		"no-alert": "warn",
		"no-debugger": "error",
		"no-duplicate-imports": "warn",
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["@/components/**", "!@/components/*", "@/components/**/../../*"],
            "message": "UI 레이어에서 상위 레이어로의 역의존을 금지합니다."
          },
          {
            "group": ["@/app/**", "!@/app/*", "@/app/**/../../*"],
            "message": "App 라우터 레이어에서 하위 레이어만 참조하세요."
          }
        ]
      }
    ],
		"import/no-cycle": ["warn", { "maxDepth": 1 }],
    "import/no-restricted-paths": [
      "error",
      {
        "zones": [
          {
            "target": "./src/components",
            "from": "./src/repositories",
            "message": "Components should not import directly from Repositories. Use Actions or Hooks."
          },
          {
            "target": "./src/lib",
            "from": "./src/components",
            "message": "Lib utilities should not depend on UI components."
          },
          {
            "target": "./src/lib",
            "from": "./src/app",
            "message": "Lib utilities should not depend on App pages."
          }
        ]
      }
    ]
  }
}
