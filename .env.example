# Database
DATABASE_URL="postgresql://user:password@host:6543/database?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/database"

# NextAuth
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# Or use: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-or-node"
NEXTAUTH_URL="http://localhost:3000"

# Vercel Blob
BLOB_READ_WRITE_TOKEN="your-blob-token"

# Upstash Redis
UPSTASH_REDIS_REST_URL="your-upstash-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Resend
RESEND_API_KEY="your-resend-key"

# Inngest
INNGEST_EVENT_KEY="your-inngest-key"
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# Mattermost (선택사항)
MATTERMOST_WEBHOOK_URL="your-mattermost-webhook"

# Sentry (선택사항)
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"

# Axiom (선택사항)
NEXT_PUBLIC_AXIOM_TOKEN="your-axiom-token"

# Rate Limiting (선택사항 - 기본값 사용 시 생략 가능)
# STRICT: 로그인, 회원가입 등 민감한 작업 (기본: 1분당 5회)
RATE_LIMIT_STRICT_WINDOW_MS="60000"
RATE_LIMIT_STRICT_MAX_REQUESTS="5"

# STANDARD: 일반 API (기본: 1분당 100회)
RATE_LIMIT_STANDARD_WINDOW_MS="60000"
RATE_LIMIT_STANDARD_MAX_REQUESTS="100"

# RELAXED: 읽기 전용 API (기본: 1분당 300회)
RATE_LIMIT_RELAXED_WINDOW_MS="60000"
RATE_LIMIT_RELAXED_MAX_REQUESTS="300"

# FILE_UPLOAD: 파일 업로드 (기본: 1시간당 20회)
RATE_LIMIT_FILE_UPLOAD_WINDOW_MS="3600000"
RATE_LIMIT_FILE_UPLOAD_MAX_REQUESTS="20"
