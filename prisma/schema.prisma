// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "windows"]
  // Vercel 배포 호환성을 위해 기본 경로 사용
  // output = "../src/generated/prisma" // 커스텀 경로는 Vercel에서 문제 발생
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// 인증 및 사용자 관리
// ============================================================================

model User {
  id            String    @id @default(cuid()) @db.VarChar(30)
  email         String    @unique @db.VarChar(255)
  name          String    @db.VarChar(50)
  password      String    @db.VarChar(255)
  emailVerified DateTime? @map("email_verified") @db.Timestamptz
  image         String?   @db.VarChar(1024)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  roles     UserRole[]
  clients   UserClient[]
  auditLogs AuditLog[]

  // SR Relations
  createdSRs      SR[]              @relation("SRRequester")
  assignedSRs     SR[]              @relation("SRAssignee")
  intakedSRs      SR[]              @relation("SRIntakeBy")
  srActivities    SRActivity[]
  srComments      SRComment[]
  srStatusHistory SRStatusHistory[] @relation("StatusChangeUser")

  // ServiceCategory Relations
  handledCategories ServiceCategory[] @relation("CategoryHandler")
  backupCategories  ServiceCategory[] @relation("CategoryBackupHandler")

  // ClientHandler Relations
  clientHandlers ClientHandler[] @relation("ClientHandlerUser")
  backupHandlers ClientHandler[] @relation("ClientHandlerBackup")

  // Push Notification Relations
  pushSubscriptions      PushSubscription[]
  notificationPreference NotificationPreference?

  @@index([email])
  @@index([isActive])
  @@map("users")
}



// ============================================================================
// 권한 관리 (RBAC)
// ============================================================================

model Role {
  id          String   @id @default(cuid()) @db.VarChar(30)
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(cuid()) @db.VarChar(30)
  userId    String   @map("user_id") @db.VarChar(30)
  roleId    String   @map("role_id") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model Permission {
  id          String  @id @default(cuid()) @db.VarChar(30)
  resource    String  @db.VarChar(50)
  action      String  @db.VarChar(50)
  description String? @db.VarChar(255)

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid()) @db.VarChar(30)
  roleId       String   @map("role_id") @db.VarChar(30)
  permissionId String   @map("permission_id") @db.VarChar(30)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ============================================================================
// 고객사 관리
// ============================================================================

model Client {
  id                String    @id @default(cuid()) @db.VarChar(30)
  code              String    @unique @db.VarChar(50)
  name              String    @db.VarChar(100)
  industry          String?   @db.VarChar(100)
  contactPerson     String?   @map("contact_person") @db.VarChar(50)
  contactEmail      String?   @map("contact_email") @db.VarChar(255)
  contactPhone      String?   @map("contact_phone") @db.VarChar(30)
  address           String?   @db.VarChar(500)
  contractStartDate DateTime? @map("contract_start_date") @db.Timestamptz
  contractEndDate   DateTime? @map("contract_end_date") @db.Timestamptz
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  users             UserClient[]
  srs               SR[]
  serviceCategories ServiceCategory[]
  clientHandlers    ClientHandler[]

  @@index([name])
  @@index([code])
  @@index([isActive])
  @@map("clients")
}

model UserClient {
  id        String   @id @default(cuid()) @db.VarChar(30)
  userId    String   @map("user_id") @db.VarChar(30)
  clientId  String   @map("client_id") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([clientId])
  @@map("user_clients")
}

model ServiceCategory {
  id              String     @id @default(cuid()) @db.VarChar(30)
  clientId        String?    @map("client_id") @db.VarChar(30)
  categoryName    String     @map("category_name") @db.VarChar(100)
  description     String?    @db.VarChar(255)
  slaHours        Int        @map("sla_hours")
  priority        SRPriority @default(MEDIUM)
  handlerId       String?    @map("handler_id") @db.VarChar(30)
  backupHandlerId String?    @map("backup_handler_id") @db.VarChar(30)
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  client        Client? @relation(fields: [clientId], references: [id])
  handler       User?   @relation("CategoryHandler", fields: [handlerId], references: [id])
  backupHandler User?   @relation("CategoryBackupHandler", fields: [backupHandlerId], references: [id])
  srs           SR[]

  @@index([clientId])
  @@index([handlerId])
  @@map("service_categories")
}

model ClientHandler {
  id              String    @id @default(cuid()) @db.VarChar(30)
  clientId        String    @map("client_id") @db.VarChar(30)
  userId          String    @map("user_id") @db.VarChar(30)
  mattermostId    String?   @map("mattermost_id") @db.VarChar(100)
  backupHandlerId String?   @map("backup_handler_id") @db.VarChar(30)
  assignedDate    DateTime  @default(now()) @map("assigned_date") @db.Timestamptz
  unassignedDate  DateTime? @map("unassigned_date") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  client        Client @relation(fields: [clientId], references: [id])
  user          User   @relation("ClientHandlerUser", fields: [userId], references: [id])
  backupHandler User?  @relation("ClientHandlerBackup", fields: [backupHandlerId], references: [id])

  @@unique([clientId, userId])
  @@index([userId])
  @@map("client_handlers")
}

// ============================================================================
// SR 관리
// ============================================================================

enum SRStatus {
  REQUESTED
  INTAKE
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CONFIRMED
  REJECTED
}

enum SRPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

model SR {
  id          String     @id @default(cuid()) @db.VarChar(30)
  srNumber    String     @unique @map("sr_number")
  title       String     @db.VarChar(255)
  description String
  status      SRStatus   @default(REQUESTED)
  priority    SRPriority @default(MEDIUM)

  // ===== 요청자 입력 필드 =====
  requestedPriority       SRPriority @default(MEDIUM) @map("requested_priority")
  requestedCompletionDate DateTime?  @map("requested_completion_date") @db.Timestamptz

  clientId          String  @map("client_id") @db.VarChar(30)
  requesterId       String  @map("requester_id") @db.VarChar(30)
  assigneeId        String? @map("assignee_id") @db.VarChar(30)
  serviceCategoryId String  @map("service_category_id") @db.VarChar(30)

  // ===== 접수자 분석 필드 =====
  intakeById              String?     @map("intake_by_id") @db.VarChar(30)
  actualPriority          SRPriority? @map("actual_priority")
  intakeNotes             String?     @map("intake_notes")
  estimatedHours          Decimal?    @map("estimated_hours") @db.Decimal(10, 2)
  estimatedCompletionDate DateTime?   @map("estimated_completion_date") @db.Timestamptz

  requestedAt            DateTime  @default(now()) @map("requested_at") @db.Timestamptz
  intakeAt               DateTime? @map("intake_at") @db.Timestamptz
  completedAt            DateTime? @map("completed_at") @db.Timestamptz
  confirmedAt            DateTime? @map("confirmed_at") @db.Timestamptz
  dueDate                DateTime? @map("due_date") @db.Timestamptz
  expectedCompletionDate DateTime? @map("expected_completion_date") @db.Timestamptz
  actualCompletionDate   DateTime? @map("actual_completion_date") @db.Timestamptz

  resolutionDescription String? @map("resolution_description")
  rejectionReason       String? @map("rejection_reason")

  satisfactionRating Int?    @map("satisfaction_rating") @db.SmallInt
  additionalFeedback String? @map("additional_feedback")

  attachmentCount Int @default(0) @map("attachment_count")
  commentCount    Int @default(0) @map("comment_count")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  client          Client            @relation(fields: [clientId], references: [id])
  requester       User              @relation("SRRequester", fields: [requesterId], references: [id])
  assignee        User?             @relation("SRAssignee", fields: [assigneeId], references: [id])
  intakeBy        User?             @relation("SRIntakeBy", fields: [intakeById], references: [id])
  serviceCategory ServiceCategory   @relation(fields: [serviceCategoryId], references: [id])
  activities      SRActivity[]
  comments        SRComment[]
  attachments     SRAttachment[]
  statusHistory   SRStatusHistory[]

  @@index([clientId, status])
  @@index([requesterId, createdAt])
  @@index([assigneeId, status])
  @@index([serviceCategoryId])
  @@index([status, priority, createdAt])
  @@index([intakeById])
  @@map("srs")
}

enum SRActivityType {
  CREATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  REASSIGNED
  COMMENTED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
  REOPENED
  COMPLETED
  REJECTED
  INTAKE_UPDATED
}

model SRActivity {
  id          String         @id @default(cuid()) @db.VarChar(30)
  srId        String         @map("sr_id") @db.VarChar(30)
  userId      String         @map("user_id") @db.VarChar(30)
  type        SRActivityType
  description String
  metadata    Json?
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz

  sr   SR   @relation(fields: [srId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([srId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("sr_activities")
}

model SRComment {
  id         String   @id @default(cuid()) @db.VarChar(30)
  srId       String   @map("sr_id") @db.VarChar(30)
  userId     String   @map("user_id") @db.VarChar(30)
  content    String
  isInternal Boolean  @default(false) @map("is_internal")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  sr   SR   @relation(fields: [srId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([srId, createdAt(sort: Desc)])
  @@index([srId, isInternal, createdAt(sort: Desc)])
  @@index([userId])
  @@map("sr_comments")
}

model SRAttachment {
  id          String   @id @default(cuid()) @db.VarChar(30)
  srId        String   @map("sr_id") @db.VarChar(30)
  fileName    String   @map("file_name") @db.VarChar(255)
  fileSize    BigInt   @map("file_size")
  fileType    String   @map("file_type") @db.VarChar(100)
  fileUrl     String   @map("file_url") @db.VarChar(1024)
  storagePath String?  @map("storage_path") @db.VarChar(1024)
  uploadedBy  String   @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  sr SR @relation(fields: [srId], references: [id], onDelete: Cascade)

  @@index([srId])
  @@map("sr_attachments")
}

// ============================================================================
// 알림 관리
// ============================================================================

enum NotificationType {
  EMAIL
  MATTERMOST
  IN_APP
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id         String             @id @default(cuid()) @db.VarChar(30)
  type       NotificationType
  status     NotificationStatus @default(PENDING)
  recipient  String
  subject    String?            @db.VarChar(255)
  content    String
  metadata   Json?
  sentAt     DateTime?          @map("sent_at") @db.Timestamptz
  failReason String?            @map("fail_reason") @db.VarChar(255)
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz

  @@index([status, createdAt])
  @@index([recipient])
  @@index([recipient, createdAt])
  @@map("notifications")
}

// ============================================================================
// SR 상태 이력
// ============================================================================

model SRStatusHistory {
  id             String    @id @default(cuid()) @db.VarChar(30)
  srId           String    @map("sr_id") @db.VarChar(30)
  previousStatus SRStatus? @map("previous_status")
  currentStatus  SRStatus  @map("current_status")
  changedBy      String    @map("changed_by") @db.VarChar(30)
  changeReason   String?   @map("change_reason")
  changedAt      DateTime  @default(now()) @map("changed_at") @db.Timestamptz

  sr   SR   @relation(fields: [srId], references: [id], onDelete: Cascade)
  user User @relation("StatusChangeUser", fields: [changedBy], references: [id])

  @@index([srId, changedAt])
  @@index([changedBy])
  @@map("sr_status_history")
}

// ============================================================================
// 푸시 알림
// ============================================================================

model PushSubscription {
  id        String   @id @default(cuid()) @db.VarChar(30)
  userId    String   @map("user_id") @db.VarChar(30)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model NotificationPreference {
  id                   String   @id @default(cuid()) @db.VarChar(30)
  userId               String   @unique @map("user_id") @db.VarChar(30)
  // Email preferences
  emailSRCreated       Boolean  @default(true) @map("email_sr_created")
  emailSRAssigned      Boolean  @default(true) @map("email_sr_assigned")
  emailSRStatusChanged Boolean  @default(false) @map("email_sr_status_changed")
  emailCommentAdded    Boolean  @default(false) @map("email_comment_added")
  // Push preferences
  pushSRCreated        Boolean  @default(true) @map("push_sr_created")
  pushSRAssigned       Boolean  @default(true) @map("push_sr_assigned")
  pushSRStatusChanged  Boolean  @default(false) @map("push_sr_status_changed")
  pushCommentAdded     Boolean  @default(false) @map("push_comment_added")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ============================================================================
// SR 번호 생성을 위한 시퀀스
// ============================================================================

model SRSequence {
  date String @id @db.VarChar(10)
  seq  Int

  @@map("sr_sequences")
}

// ============================================================================
// 전역 시스템/역할/사용자 변경 감사 로그 (Audit Log)
// ============================================================================

model AuditLog {
  id           String   @id @default(cuid()) @db.VarChar(30)
  userId       String?  @map("user_id") @db.VarChar(30)
  actionType   String   @map("action_type") @db.VarChar(50)
  targetEntity String   @map("target_entity") @db.VarChar(50)
  targetId     String?  @map("target_id")
  changes      Json     @map("changes")
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([actionType])
  @@index([createdAt])
  @@map("audit_logs")
}
