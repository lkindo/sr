# ==============================================================================
# SR MANAGEMENT SYSTEM - OPTIMIZED GITIGNORE
# ==============================================================================

# 1. Dependencies & Package Managers
# ------------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.pnpm-store/
.pnpm-debug.log*

# 2. Next.js, Vercel & Turbo Build Outputs
# ------------------------------------------------------------------------------
/.next/
/out/
/build/
/dist/
.turbo/
.vercel/
.vercelignore

# 3. Environment Variables & Credentials (CRITICAL SECRETS)
# ------------------------------------------------------------------------------
.env
.env*.local
/prisma/.env
*.pem
*.key
project.tar.gz

# 4. Prisma Generated Files
# ------------------------------------------------------------------------------
/src/generated

# 5. Playwright & Testing Frameworks
# ------------------------------------------------------------------------------
/playwright-report/
/playwright/.cache/
/coverage/
/test-results/
.stryker-tmp/

# Playwright 인증 정보 세션 (민감 데이터 누출 차단)
playwright/.auth/

# 6. Temporary Logs & Test Results (Generalized wildcard patterns)
# ------------------------------------------------------------------------------
*.log
*.log*
*_debug.log
*_output.txt
*_verbose.txt
*results.txt
*result.json
coverage_summary.txt
coverage_summary_utf8.txt
build_error.log
eslint_results.txt
eslint_output.txt
eslintcache
.eslintcache

# 7. Local Media & Storybook Uploads
# ------------------------------------------------------------------------------
public/uploads/*
!public/uploads/.gitkeep
*storybook.log
storybook-static/

# 8. OS & Common Editor Settings (Includes MS Office Lock files)
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
nul

# MS Office (Word, Excel, PowerPoint) 임시/락 파일 차단 (시스템 매뉴얼 파워포인트 편집용)
~$*
~$*.docx
~$*.xlsx
~$*.pptx

# IDEs
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# 9. Other Temporary & Generated Assets
# ------------------------------------------------------------------------------
actions_runs.json
output.css
tsconfig.tsbuildinfo
next-env.d.ts
