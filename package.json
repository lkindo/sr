{
  "name": "sr-management",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:test": "cross-env SKIP_ENV_VALIDATION=true next dev --turbopack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "analyze": "cross-env ANALYZE=true next build",
    "type-check": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "test:mutation:ci": "tsx scripts/stryker-ci.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:multi-user": "playwright test --project=multi-user",
    "test:e2e:setup": "playwright test --project=multi-user-setup",
    "test:e2e:collaboration": "playwright test e2e/17-multi-user-collaboration.spec.ts",
    "test:e2e:reassignment": "playwright test e2e/18-sr-reassignment-escalation.spec.ts",
    "test:e2e:files": "playwright test e2e/19-file-upload-download.spec.ts",
    "test:e2e:notifications": "playwright test e2e/20-notification-system.spec.ts",
    "report:slow-queries": "tsx scripts/summarize-slow-queries.ts",
    "warm:dashboard": "tsx scripts/warm-dashboard.ts",
    "cleanup:system-team-clients": "tsx scripts/cleanup-system-team-clients.ts",
    "cleanup:system-team-clients:dry-run": "tsx scripts/cleanup-system-team-clients.ts --dry-run",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vercel/functions": "^3.4.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "file-type": "^21.3.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "nodemailer": "^7.0.11",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "recharts": "3.7.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@chromatic-com/storybook": "^5.0.0",
    "@eslint/js": "^9.39.2",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.7",
    "@storybook/addon-docs": "^10.2.7",
    "@storybook/addon-onboarding": "^10.2.7",
    "@storybook/addon-vitest": "^10.2.7",
    "@storybook/nextjs": "^10.2.7",
    "@storybook/nextjs-vite": "^10.2.7",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.2",
    "@types/nodemailer": "^7.0.9",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.4",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^10.2.7",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.9",
    "pino": "^10.3.0",
    "playwright": "^1.58.2",
    "postcss": "^8",
    "prisma": "^6.19.0",
    "storybook": "^10.2.7",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-mock-extended": "^3.1.0"
  },
  "trustedDependencies": [
    "@prisma/client",
    "@prisma/engines",
    "esbuild",
    "msw",
    "prisma",
    "sharp",
    "unrs-resolver"
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "vitest related --run --project=unit"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
